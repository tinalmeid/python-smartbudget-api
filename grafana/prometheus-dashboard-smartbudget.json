{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Prometheus (Mimir)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [],
  "title": "💰 python-smartbudget-api — Métricas",
  "description": "Dashboard de métricas do projeto python-smartbudget-api",
  "uid": "python-smartbudget-api-prometheus",
  "tags": ["python-smartbudget-api", "prometheus"],
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [

    {
      "id": 1,
      "title": "✅ Status do Pipeline",
      "description": "Resultado do último pipeline (1 = sucesso, 0 = falha)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FALHOU" }, "1": { "text": "PASSOU" } } }
          ],
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "smartbudget_pipeline_success{project=\"python-smartbudget-api\"}",
          "legendFormat": "Status",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "⏱️ Duração do Pipeline (segundos)",
      "description": "Tempo total de execução do pipeline em segundos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red",    "value": 300 }
            ]
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "smartbudget_pipeline_duration_seconds{project=\"python-smartbudget-api\"}",
          "legendFormat": "Duração",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "📈 Histórico de Duração do Pipeline",
      "description": "Evolução do tempo de build ao longo do tempo — detecta degradação de performance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "min"],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "smartbudget_pipeline_duration_seconds",
          "legendFormat": "{{branch}}",
          "refId": "A"
        }
      ]
    }

  ]
}
