# === Ambiente ===
APP_ENV=development

# === JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))" ===
SECRET_KEY=TROQUE_POR_UM_VALOR_SECRETO_REAL
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === PlanetScale MySQL — 1 banco por serviço ===
# Formato: mysql+pymysql://USER:PASS@HOST/DB?ssl_ca=/etc/ssl/certs/ca-certificates.crt
DB_USUARIOS_URL=mysql+pymysql://usuario:senha@HOST/db_usuarios?ssl_ca=/etc/ssl/certs/ca-certificates.crt
DB_ORCAMENTO_URL=mysql+pymysql://usuario:senha@HOST/db_orcamento?ssl_ca=/etc/ssl/certs/ca-certificates.crt
DB_PREVISAO_URL=mysql+pymysql://usuario:senha@HOST/db_previsao?ssl_ca=/etc/ssl/certs/ca-certificates.crt
DB_NOTIFICACOES_URL=mysql+pymysql://usuario:senha@HOST/db_notificacoes?ssl_ca=/etc/ssl/certs/ca-certificates.crt

# === Kafka — Confluent Cloud ===
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_SASL_USERNAME=SUA_API_KEY_CONFLUENT
KAFKA_SASL_PASSWORD=SUA_API_SECRET_CONFLUENT

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === AWS ===
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
MLFLOW_S3_BUCKET=smartbudget-mlflow

# === Observabilidade ===
DATADOG_API_KEY=sua_api_key_datadog

# === Notificações ===
SENDGRID_API_KEY=SG.xxxxx
FIREBASE_CREDENTIALS_JSON=/run/secrets/firebase_creds
